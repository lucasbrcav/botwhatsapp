# Variáveis de ambiente — copie para .env e preencha os valores

# ----- WAHA (Gateway WhatsApp) -----
# Chave de API para autenticar requisições ao WAHA
WAHA_API_KEY=mude_esta_chave_secreta

# URL interna do WAHA (usado pelo backend dentro do Docker)
WAHA_URL=http://waha:3000

# ----- Autenticação do Admin Panel -----
# Usuário do painel administrativo
ADMIN_USER=admin

# Hash bcrypt da senha do admin (gere com: node -e "require('bcryptjs').hash('suasenha',10).then(console.log)")
# Padrão: "admin123" (TROQUE EM PRODUÇÃO!)
ADMIN_PASS_HASH=$2a$10$N9qo8uLOickgx2ZMRZoMyeIjZAgcfl7p92ldGxad68LJZdL17lhWy

# ----- JWT -----
# Segredo para assinar tokens JWT (use uma string longa e aleatória)
JWT_SECRET=troque_por_string_aleatoria_longa_de_ao_menos_32_caracteres

# ----- Webhook -----
# Segredo compartilhado para autenticar webhooks recebidos do WAHA
WEBHOOK_SECRET=outro_segredo_aleatorio_aqui

# ----- Nginx / URL pública -----
# URL pública do servidor (usada pelo browser para chamar a API via nginx)
PUBLIC_URL=http://localhost

# Origem permitida para CORS no backend (mesma que PUBLIC_URL)
ADMIN_ORIGIN=http://localhost
